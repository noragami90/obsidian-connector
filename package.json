{
  "name": "obsidian-connector",
  "version": "0.1.0",
  "description": "Local MCP connector for Obsidian — read, write and search Markdown notes in any vault directly on disk.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Anton"
  },
  "main": "dist/index.js",
  "bin": {
    "obsidian-connector": "dist/index.js"
  },
  "files": [
    "dist",
    "manifest.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc --noEmit && node esbuild.mjs",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "pack": "npm run build && npx @anthropic-ai/mcpb pack"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^1.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "sharp": "^0.35.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
